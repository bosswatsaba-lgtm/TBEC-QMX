generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Phase {
  EARTHWORKS
  SUBSTRUCTURE
  SUPERSTRUCTURE
  ROOFING
  FINISHES
}

enum ProjectStatus {
  DRAFT
  CALCULATING
  READY
  REVISION
}

enum MeasurementUnit {
  M
  M2
  M3
  T
  KG
  HR
  DAY
}

model Tenant {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  projects  Project[]
}

model Project {
  id          String        @id @default(cuid())
  name        String
  client      String?
  location    String?
  region      String?
  currency    String        @default("USD")
  status      ProjectStatus @default(DRAFT)
  totalValue  Float?
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  measurements Measurement[]
  boqItems    BoqItem[]
  phases      PhaseProgress[]
}

model PhaseProgress {
  id        String @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id])
  phase     Phase
  pct       Int     @default(0)
  quantified Float?
  total     Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, phase])
}

model Measurement {
  id        String          @id @default(cuid())
  label     String
  phase     Phase
  smm7Code  String?
  value     Float
  unit      MeasurementUnit @default(M)
  active    Boolean         @default(false)
  projectId String
  project   Project         @relation(fields: [projectId], references: [id])
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model BoqItem {
  id          String   @id @default(cuid())
  code        String
  description String
  unit        String
  quantity    Float
  rate        Float
  total       Float
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MaterialCategory {
  id       String         @id @default(cuid())
  name     String         @unique
  materials MaterialRate[]
}

model Supplier {
  id        String         @id @default(cuid())
  name      String
  materials MaterialRate[]
}

model MaterialRate {
  id              String           @id @default(cuid())
  code            String           @unique
  name            String
  unit            String
  rate            Float
  wastage         Float            @default(0)
  categoryId      String
  category        MaterialCategory @relation(fields: [categoryId], references: [id])
  supplierId      String?
  supplier        Supplier?        @relation(fields: [supplierId], references: [id])
  lastUpdated     DateTime         @default(now())
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}
